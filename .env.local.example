# 지원각 환경변수 템플릿
# 사용법: cp .env.local.example .env.local 후 실제 값 채우기.
# .env.local은 .gitignore에 포함되어 커밋되지 않음.

# === 사이트 URL (OG 이미지 등 절대 URL 생성에 사용) ===
# 운영 배포 시 실제 URL 입력 (예: https://jiwongak.vercel.app)
# Vercel에서는 VERCEL_URL이 자동 주입되므로 미설정 시 해당 값 사용
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Supabase ===
# 클라이언트 (anon key, RLS 적용) — 브라우저 번들에 포함됨
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...

# 서버 (service role key, RLS 우회) — 절대 클라이언트로 노출 금지
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# === Anthropic Claude ===
# 공고 파싱(Haiku) + 매칭 분석(Sonnet) 사용
ANTHROPIC_API_KEY=sk-ant-api03-...

# === Voyage AI (임베딩) ===
# voyage-3 (1024 dim, asymmetric) — 시드/검색 모두 사용
VOYAGE_API_KEY=pa-...

# === Sentry (에러 모니터링) ===
# Sentry 프로젝트 설정 → Settings > Projects > Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oxx.ingest.sentry.io/xxx
# 소스맵 업로드용 (빌드 시에만 사용, 런타임 불필요)
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=jiwongak
SENTRY_AUTH_TOKEN=sntrys_...

# === Upstash Redis (Rate Limiting) ===
# Vercel 대시보드 → Storage → Upstash → Redis 생성 → Connect to Project
# 연결 후 Vercel이 아래 변수를 자동 주입 (로컬은 vercel env pull로 가져올 것)
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...
# 미설정 시 rate limit 비활성화 (로컬 개발 시 비워둬도 무방)

# === 분석 옵션 (선택) ===
# 임시로 LLM 호출 끄고 더미 응답 사용 (UI 개발 시 비용 절감)
# MOCK_ANALYSIS=true
